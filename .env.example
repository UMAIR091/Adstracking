# ─── Supabase (required) ───
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
SUPABASE_SERVICE_ROLE_KEY="ey..."     # server-only; never expose to the browser

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TOKEN_ENCRYPTION_KEY=""                # 32-byte base64 key for encrypting stored OAuth tokens

# ─── Google OAuth + APIs (required for data sources) ───
# Google Cloud Console → create OAuth client (Web), enable Search Console API + GA4 Data API.
# Google's OAuth consent screen needs verification before public use (can take days).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"

# ─── Google Ads API ───
# Reuses the Google OAuth app above (adds the adwords scope at connect time).
# Get a developer token from a Google Ads MANAGER account → Tools → API Center.
# While the token is pending approval it works against test accounts only.
GOOGLE_ADS_DEVELOPER_TOKEN=""
# Set when your access runs through a manager (MCC) account: its customer id, digits only.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
# Optional: override the API version (defaults to v21).
GOOGLE_ADS_API_VERSION=""

# ─── Google Business Profile ───
# No extra env vars — reuses the Google OAuth app (business.manage scope).
# In Google Cloud, enable: My Business Account Management API, My Business
# Business Information API, Business Profile Performance API. Note: Google
# gates GBP API access behind a request form (search "Business Profile API
# access request"); until approved these calls return PERMISSION_DENIED.

# ─── Meta (Facebook + Instagram) OAuth + Graph API ───
# One Meta app powers BOTH Meta Ads and Instagram — no extra env vars for Instagram.
# developers.facebook.com → create an app (type "Business") → add "Facebook Login"
# and the "Marketing API" products. Under Facebook Login → Settings, add the redirect
# URI below to "Valid OAuth Redirect URIs".
# Meta Ads requests: ads_read + business_management.
# Instagram requests: instagram_basic + instagram_manage_insights + pages_show_list
#   + pages_read_engagement + business_management (professional IG account linked
#   to a Facebook Page required).
# In Dev Mode add yourself as a Tester, or submit for App Review to use with other users.
META_APP_ID=""
META_APP_SECRET=""
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/meta/callback"
# Optional: override the Graph API version (defaults to v21.0).
META_API_VERSION=""

# ─── Shopify ───
# partners.shopify.com → create an app (or a custom app) → API credentials.
# Allowed redirection URL: <APP_URL>/api/shopify/callback
# Request the read_orders (+ protected customer data) access for production stores.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
# Optional overrides: comma-separated scopes (default read_orders,read_products)
# and Admin API version (default 2025-07).
SHOPIFY_SCOPES=""
SHOPIFY_API_VERSION=""

# ─── HubSpot ───
# developers.hubspot.com → create an app → Auth. Redirect URL:
# <APP_URL>/api/hubspot/callback. Scopes: oauth, crm.objects.contacts.read,
# crm.objects.deals.read.
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# ─── LinkedIn Ads ───
# developer.linkedin.com → create an app → request "Advertising API" access
# (Marketing Developer Platform — approval required; refresh tokens come with
# it). Auth redirect URL: <APP_URL>/api/linkedin/callback.
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
# Optional: LinkedIn-Version header override (default 202506).
LINKEDIN_API_VERSION=""

# ─── TikTok Ads ───
# business-api.tiktok.com → TikTok for Business developer portal → create an
# app (approval required). Advertiser redirect URL: <APP_URL>/api/tiktok/callback.
# Scopes: Ad Account Management (read) + Reporting.
TIKTOK_APP_ID=""
TIKTOK_APP_SECRET=""

# ─── Pinterest Ads (Pinterest REST API v5) ───
# https://developers.pinterest.com → Apps → create an app (App ID + secret key).
# Requires a Pinterest business account; standard (non-trial) access needs app
# review to connect clients' accounts. Redirect URL: <APP_URL>/api/pinterest/callback.
# Scopes: ads:read + user_accounts:read (read-only).
PINTEREST_APP_ID=""
PINTEREST_APP_SECRET=""

# ─── Snapchat Ads (Snapchat Marketing API v1) ───
# https://business.snapchat.com → Business Details → OAuth apps (or
# developers.snap.com). Redirect URL: <APP_URL>/api/snapchat/callback.
# Scope: snapchat-marketing-api (read-only reporting). Access token lives ~1h;
# the refresh token keeps sync running.
SNAPCHAT_CLIENT_ID=""
SNAPCHAT_CLIENT_SECRET=""

# ─── Reddit Ads (Reddit Ads API v3) ───
# https://www.reddit.com/prefs/apps → create a "web app" (client id + secret).
# Reddit Ads API access is allow-list/approval gated — request Ads API access.
# Redirect URL: <APP_URL>/api/reddit/callback. Scope: adsread identity.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# ─── Amazon Ads (Amazon Advertising API v3) ───
# Login with Amazon app (developer.amazon.com) + Amazon Ads API access, which
# requires an application/approval. Redirect URL: <APP_URL>/api/amazon/callback.
# Scope: advertising::campaign_management. Reporting is async (create → poll).
# AMAZON_ADS_REGION: NA (default) | EU | FE — must match the account's region.
AMAZON_ADS_CLIENT_ID=""
AMAZON_ADS_CLIENT_SECRET=""
AMAZON_ADS_REGION="NA"

# ─── X Ads (X/Twitter Ads API v12) ───
# developer.x.com → app (consumer key + secret). X's Ads API uses OAuth 1.0a and
# requires approved Ads API access (application) on a paid developer tier.
# Callback URL (register in the app): <APP_URL>/api/x/callback
X_ADS_CONSUMER_KEY=""
X_ADS_CONSUMER_SECRET=""

# ─── Adobe Analytics (Analytics 2.0 API) ───
# developer.adobe.com → project → add Adobe Analytics API → OAuth Web App
# credential. Requires an enterprise Adobe Analytics product profile.
# Redirect URI: <APP_URL>/api/adobe/callback
# Scopes: openid, AdobeID, read_organizations, additional_info.projectedProductContext
ADOBE_CLIENT_ID=""
ADOBE_CLIENT_SECRET=""

# ─── Salesforce (REST/SOQL API) ───
# Setup → App Manager → New Connected App → Enable OAuth. Callback URL:
# <APP_URL>/api/salesforce/callback. Scopes: api, refresh_token (offline access).
# SALESFORCE_LOGIN_URL: https://login.salesforce.com (default) or
# https://test.salesforce.com for sandboxes.
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
SALESFORCE_LOGIN_URL=""

# ─── ActiveCampaign ───
# No app credentials needed — each agency connects a client by pasting that
# account's API URL + key (ActiveCampaign → Settings → Developer). Always live.

# ─── AI report summaries (Anthropic) ───
# https://platform.claude.com → API keys. When set, every generated report gets a
# Claude-written executive summary, highlights, and recommendations. Leave blank to
# disable (reports still generate, just without the AI section).
ANTHROPIC_API_KEY=""
# Optional: override the model. Defaults to claude-opus-4-8 (most capable).
# Use claude-sonnet-4-6 or claude-haiku-4-5 to lower cost per report.
AI_MODEL=""

# ─── Email (Resend) ───
# https://resend.com → API keys; verify a sending domain for white-label sender.
RESEND_API_KEY=""
EMAIL_FROM="ReportFlow <reports@yourdomain.com>"

# ─── Billing (Lemon Squeezy — Merchant of Record, pays to Payoneer) ───
# https://lemonsqueezy.com → Settings → API. Create a Store, then a Product per
# plan with a monthly + annual Variant each; paste the variant IDs below.
# A plan only appears in the app when at least one of its variant IDs is set.
# Webhook: Settings → Webhooks → add <APP_URL>/api/billing/webhook with the
# subscription_* events; the signing secret goes in LEMONSQUEEZY_WEBHOOK_SECRET.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Plans (create a Product per plan with monthly + annual variants). Prices +
# client limits live in src/lib/billing/config.ts; only variant IDs go here.
# A plan appears in the pricing UI only once at least one variant is set.
#   Pro       $49/mo  · up to 5 clients
#   Pro Plus  $95/mo  · up to 10 clients
#   Growth    $149/mo · up to 25 clients
#   Agency    $299/mo · up to 100 clients
LEMONSQUEEZY_VARIANT_ID_PRO_MONTHLY=""
LEMONSQUEEZY_VARIANT_ID_PRO_ANNUAL=""
LEMONSQUEEZY_VARIANT_ID_PRO_PLUS_MONTHLY=""
LEMONSQUEEZY_VARIANT_ID_PRO_PLUS_ANNUAL=""
LEMONSQUEEZY_VARIANT_ID_GROWTH_MONTHLY=""
LEMONSQUEEZY_VARIANT_ID_GROWTH_ANNUAL=""
LEMONSQUEEZY_VARIANT_ID_AGENCY_MONTHLY=""
LEMONSQUEEZY_VARIANT_ID_AGENCY_ANNUAL=""
# Legacy names (still honored as Pro fallbacks):
# LEMONSQUEEZY_VARIANT_ID_MONTHLY / LEMONSQUEEZY_VARIANT_ID_ANNUAL

# ─── Scheduler ───
CRON_SECRET=""                         # protects /api/cron/run-schedules
