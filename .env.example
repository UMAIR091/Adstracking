# ─── Supabase (required) ───
# Create a project at https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="ey..."
SUPABASE_SERVICE_ROLE_KEY="ey..."     # server-only; never expose to the browser

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TOKEN_ENCRYPTION_KEY=""                # 32-byte base64 key for encrypting stored OAuth tokens

# ─── Google OAuth + APIs (required for data sources) ───
# Google Cloud Console → create OAuth client (Web), enable Search Console API + GA4 Data API.
# Google's OAuth consent screen needs verification before public use (can take days).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/callback"

# ─── Google Ads API ───
# Reuses the Google OAuth app above (adds the adwords scope at connect time).
# Get a developer token from a Google Ads MANAGER account → Tools → API Center.
# While the token is pending approval it works against test accounts only.
GOOGLE_ADS_DEVELOPER_TOKEN=""
# Set when your access runs through a manager (MCC) account: its customer id, digits only.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""
# Optional: override the API version (defaults to v21).
GOOGLE_ADS_API_VERSION=""

# ─── Google Business Profile ───
# No extra env vars — reuses the Google OAuth app (business.manage scope).
# In Google Cloud, enable: My Business Account Management API, My Business
# Business Information API, Business Profile Performance API. Note: Google
# gates GBP API access behind a request form (search "Business Profile API
# access request"); until approved these calls return PERMISSION_DENIED.

# ─── Meta (Facebook + Instagram) OAuth + Graph API ───
# One Meta app powers BOTH Meta Ads and Instagram — no extra env vars for Instagram.
# developers.facebook.com → create an app (type "Business") → add "Facebook Login"
# and the "Marketing API" products. Under Facebook Login → Settings, add the redirect
# URI below to "Valid OAuth Redirect URIs".
# Meta Ads requests: ads_read + business_management.
# Instagram requests: instagram_basic + instagram_manage_insights + pages_show_list
#   + pages_read_engagement + business_management (professional IG account linked
#   to a Facebook Page required).
# In Dev Mode add yourself as a Tester, or submit for App Review to use with other users.
META_APP_ID=""
META_APP_SECRET=""
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/meta/callback"
# Optional: override the Graph API version (defaults to v21.0).
META_API_VERSION=""

# ─── Shopify ───
# partners.shopify.com → create an app (or a custom app) → API credentials.
# Allowed redirection URL: <APP_URL>/api/shopify/callback
# Request the read_orders (+ protected customer data) access for production stores.
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
# Optional overrides: comma-separated scopes (default read_orders,read_products)
# and Admin API version (default 2025-07).
SHOPIFY_SCOPES=""
SHOPIFY_API_VERSION=""

# ─── HubSpot ───
# developers.hubspot.com → create an app → Auth. Redirect URL:
# <APP_URL>/api/hubspot/callback. Scopes: oauth, crm.objects.contacts.read,
# crm.objects.deals.read.
HUBSPOT_CLIENT_ID=""
HUBSPOT_CLIENT_SECRET=""

# ─── AI report summaries (Anthropic) ───
# https://platform.claude.com → API keys. When set, every generated report gets a
# Claude-written executive summary, highlights, and recommendations. Leave blank to
# disable (reports still generate, just without the AI section).
ANTHROPIC_API_KEY=""
# Optional: override the model. Defaults to claude-opus-4-8 (most capable).
# Use claude-sonnet-4-6 or claude-haiku-4-5 to lower cost per report.
AI_MODEL=""

# ─── Email (Resend) ───
# https://resend.com → API keys; verify a sending domain for white-label sender.
RESEND_API_KEY=""
EMAIL_FROM="ReportFlow <reports@yourdomain.com>"

# ─── Billing (Lemon Squeezy — Merchant of Record, pays to Payoneer) ───
# https://lemonsqueezy.com → Settings → API. Create a Store, then a Product per
# plan with a monthly + annual Variant each; paste the variant IDs below.
# A plan only appears in the app when at least one of its variant IDs is set.
# Webhook: Settings → Webhooks → add <APP_URL>/api/billing/webhook with the
# subscription_* events; the signing secret goes in LEMONSQUEEZY_WEBHOOK_SECRET.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_VARIANT_ID_PRO_MONTHLY=""
LEMONSQUEEZY_VARIANT_ID_PRO_ANNUAL=""
LEMONSQUEEZY_VARIANT_ID_TEAM_MONTHLY=""   # optional — Team plan hides until set
LEMONSQUEEZY_VARIANT_ID_TEAM_ANNUAL=""    # optional
LEMONSQUEEZY_WEBHOOK_SECRET=""
# Legacy names (still honored as Pro fallbacks):
# LEMONSQUEEZY_VARIANT_ID_MONTHLY / LEMONSQUEEZY_VARIANT_ID_ANNUAL

# ─── Scheduler ───
CRON_SECRET=""                         # protects /api/cron/run-schedules
